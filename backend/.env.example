# Ghost CMS — copy to .env, fill in, never commit .env

# The public URL Ghost serves at (via Cloudflare Tunnel or direct domain)
GHOST_PUBLIC_URL=https://cms.wasimi.yourdomain.com
GHOST_HOSTNAME=cms.wasimi.yourdomain.com

# MySQL passwords — generate strong random strings
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# SMTP for Ghost's built-in email (newsletters, member notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=Wasimi Journal <journal@wasimi.yourdomain.com>
