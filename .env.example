# ─── Ghost CMS (set these in Cloudflare Pages environment variables) ───────────
# Your Ghost instance URL (exposed via Cloudflare Tunnel or public domain)
GHOST_URL=https://cms.wasimi.example.com

# Ghost Content API key — READ-ONLY, set as a BUILD secret in Cloudflare Pages
# Generate from Ghost Admin → Integrations → Add custom integration
GHOST_KEY=your_ghost_content_api_key_here

# ─── Google Forms URLs — NOT sensitive, public links ───────────────────────────
# Replace each placeholder after creating your Google Forms
VITE_FORM_PLEDGE=https://forms.gle/PLACEHOLDER_PLEDGE
VITE_FORM_VOLUNTEER=https://forms.gle/PLACEHOLDER_VOLUNTEER
VITE_FORM_REFER=https://forms.gle/PLACEHOLDER_REFER
VITE_FORM_SUBSCRIBE=https://forms.gle/PLACEHOLDER_SUBSCRIBE
VITE_FORM_GIVE=https://forms.gle/PLACEHOLDER_GIVE
